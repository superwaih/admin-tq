# =============================================================================
# AdmitIQ Web App (Next.js) - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# Full platform variable reference: see /admitiq-platform/.env.example
# The root .env.example is the source of truth for all env vars.

# API Core — base URL for all auth and data requests
# Outside Docker: http://localhost:8000
# Inside Docker:  http://localhost:8000 (browser requests hit the host port mapping)
NEXT_PUBLIC_API_CORE_URL=http://localhost:8000

# Web app port (used by Docker Compose and local dev server)
NEXT_PUBLIC_WEB_PORT=3000
